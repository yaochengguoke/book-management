page { background: #f5f5f5; font-family: -apple-system,'PingFang SC','Microsoft YaHei',sans-serif; }
.container { padding: 20rpx; }

/* Card */
.card { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }

/* Stats */
.stats-row { display: flex; flex-wrap: wrap; gap: 20rpx; margin-bottom: 20rpx; }
.stat-card { flex: 1; min-width: 200rpx; background: linear-gradient(135deg,#667eea,#764ba2); border-radius: 16rpx; padding: 30rpx; color: #fff; text-align: center; }
.stat-card.s2 { background: linear-gradient(135deg,#f093fb,#f5576c); }
.stat-card.s3 { background: linear-gradient(135deg,#4facfe,#00f2fe); }
.stat-card.s4 { background: linear-gradient(135deg,#43e97b,#38f9d7); }
.stat-card .num { font-size: 48rpx; font-weight: bold; }
.stat-card .label { font-size: 24rpx; opacity: 0.8; margin-top: 8rpx; }

/* List */
.list-item { display: flex; align-items: center; padding: 25rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.list-item:last-child { border-bottom: none; }
.list-item .info { flex: 1; }
.list-item .title { font-size: 30rpx; color: #333; }
.list-item .desc { font-size: 24rpx; color: #999; margin-top: 8rpx; }

/* Tags */
.tag { display: inline-block; padding: 6rpx 18rpx; border-radius: 8rpx; font-size: 22rpx; }
.tag-success { background: #e8f5e9; color: #2e7d32; }
.tag-warning { background: #fff3e0; color: #e65100; }
.tag-danger { background: #ffebee; color: #c62828; }
.tag-info { background: #e3f2fd; color: #1565c0; }
.tag-card { display: inline-block; padding: 10rpx 24rpx; background: #f0f0f0; border-radius: 20rpx; font-size: 24rpx; color: #666; margin-right: 10rpx; }

/* Buttons */
.btn-primary { background: #4A90D9; color: #fff; border: none; border-radius: 12rpx; padding: 20rpx 40rpx; font-size: 28rpx; }
.btn-danger { background: #e74c3c; color: #fff; border: none; border-radius: 12rpx; padding: 16rpx 30rpx; font-size: 24rpx; }
.btn-sm { padding: 10rpx 24rpx; font-size: 22rpx; border-radius: 8rpx; }

/* Search */
.search-bar { display: flex; padding: 20rpx; background: #fff; }
.search-bar input { flex: 1; height: 70rpx; background: #f5f5f5; border-radius: 35rpx; padding: 0 30rpx; font-size: 28rpx; }

/* Rank */
.rank-item { display: flex; align-items: center; gap: 15rpx; padding: 15rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.rank-num { font-size: 36rpx; font-weight: bold; width: 60rpx; text-align: center; }
.cover-sm { width: 80rpx; height: 100rpx; border-radius: 8rpx; background: #eee; }

/* Form */
.field { width: 100%; height: 80rpx; border: 1rpx solid #e0e0e0; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; margin-bottom: 15rpx; background: #fff; }

/* Empty */
.empty { text-align: center; padding: 100rpx 0; color: #999; font-size: 28rpx; }

/* Dark mode */
@media (prefers-color-scheme: dark) {
  page { background: #1a1a2e; }
  .card { background: #16213e; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.3); }
  .list-item { border-color: #0f3460; }
  .list-item .title { color: #e0e0e0; }
  .search-bar { background: #16213e; }
  .search-bar input { background: #0f3460; color: #e0e0e0; }
  .field { background: #0f3460; border-color: #1a1a3e; color: #e0e0e0; }
  .empty { color: #666; }
}
