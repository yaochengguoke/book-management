page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.container { padding: 20rpx; }

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 统计卡片 */
.stats-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.stat-card {
  flex: 1;
  min-width: 200rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 16rpx;
  padding: 30rpx;
  color: #fff;
  text-align: center;
}
.stat-card .num { font-size: 48rpx; font-weight: bold; }
.stat-card .label { font-size: 24rpx; opacity: 0.8; margin-top: 8rpx; }
.stat-card:nth-child(2) { background: linear-gradient(135deg, #f093fb, #f5576c); }
.stat-card:nth-child(3) { background: linear-gradient(135deg, #4facfe, #00f2fe); }
.stat-card:nth-child(4) { background: linear-gradient(135deg, #43e97b, #38f9d7); }

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 25rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.list-item:last-child { border-bottom: none; }
.list-item .info { flex: 1; }
.list-item .title { font-size: 30rpx; color: #333; }
.list-item .desc { font-size: 24rpx; color: #999; margin-top: 8rpx; }

/* 按钮 */
.btn-primary {
  background: #4A90D9;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}
.btn-danger {
  background: #e74c3c;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 30rpx;
  font-size: 24rpx;
}
.btn-sm {
  padding: 10rpx 24rpx;
  font-size: 22rpx;
  border-radius: 8rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  padding: 20rpx;
  background: #fff;
}
.search-bar input {
  flex: 1;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-success { background: #e8f5e9; color: #2e7d32; }
.tag-warning { background: #fff3e0; color: #e65100; }
.tag-danger { background: #ffebee; color: #c62828; }
.tag-info { background: #e3f2fd; color: #1565c0; }

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 表单 */
.form-group { margin-bottom: 25rpx; }
.form-group label { display: block; font-size: 28rpx; color: #333; margin-bottom: 10rpx; }
.form-group input, .form-group picker {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #fff;
}
