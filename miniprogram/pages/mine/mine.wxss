/* login modal */
.login-mask { position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:1000;display:flex;align-items:center;justify-content:center; }
.login-box { background:#fff;border-radius:16rpx;padding:40rpx;width:560rpx; }
.login-box input { width:100%;height:80rpx;border:1rpx solid #e0e0e0;border-radius:12rpx;padding:0 20rpx;margin-bottom:20rpx;font-size:28rpx; }
