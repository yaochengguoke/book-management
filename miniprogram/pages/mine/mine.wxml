<view class="container">
  <!-- 用户信息 -->
  <view class="card" style="text-align:center;">
    <view style="width:120rpx;height:120rpx;background:#e3f2fd;border-radius:50%;margin:0 auto 20rpx;line-height:120rpx;font-size:60rpx;">👤</view>
    <view style="font-size:36rpx;font-weight:bold;">{{userInfo.username || '未登录'}}</view>
    <view style="font-size:26rpx;color:#999;margin-top:8rpx;">
      <text class="tag {{userInfo.role === 'ADMIN' ? 'tag-danger' : 'tag-info'}}">{{userInfo.role === 'ADMIN' ? '管理员' : '普通用户'}}</text>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="card">
    <view wx:if="{{userInfo.role === 'ADMIN'}}" class="list-item" bindtap="goUsers">
      <view class="info"><view class="title">👥 用户管理</view></view>
      <text style="color:#ccc;">→</text>
    </view>
    <view class="list-item" bindtap="loginWithPassword">
      <view class="info"><view class="title">🔑 账号登录</view><view class="desc">使用账号密码登录系统</view></view>
      <text style="color:#ccc;">→</text>
    </view>
    <view class="list-item" bindtap="wxLogin">
      <view class="info"><view class="title">💚 微信一键登录</view><view class="desc">使用微信账号快速登录</view></view>
      <text style="color:#ccc;">→</text>
    </view>
  </view>

  <view class="card" style="text-align:center;">
    <view style="font-size:24rpx;color:#999;">智慧图书管理系统 v1.0</view>
    <view style="font-size:22rpx;color:#ccc;">支持 Web + 微信小程序</view>
  </view>
</view>
