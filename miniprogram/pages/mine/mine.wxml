<view class="container">
  <view class="card" style="text-align:center;">
    <view style="width:120rpx;height:120rpx;background:#e3f2fd;border-radius:50%;margin:0 auto 20rpx;line-height:120rpx;font-size:60rpx;">👤</view>
    <view style="font-size:36rpx;font-weight:bold;">{{userInfo.username || '未登录'}}</view>
    <text class="tag {{userInfo.role === 'ADMIN' ? 'tag-danger' : 'tag-info'}}">{{userInfo.role === 'ADMIN' ? '管理员' : '普通用户'}}</text>
  </view>

  <view class="card">
    <view wx:if="{{userInfo.role === 'ADMIN'}}" class="list-item" bindtap="goUsers">
      <view class="info"><view class="title">👥 用户管理</view></view><text style="color:#ccc;">→</text>
    </view>
    <view class="list-item" bindtap="loginWithPassword">
      <view class="info"><view class="title">🔑 密码登录</view><view class="desc">使用admin/admin登录</view></view><text style="color:#ccc;">→</text>
    </view>
    <view class="list-item" bindtap="wxLogin">
      <view class="info"><view class="title">💚 微信一键登录</view><view class="desc">微信账号快速登录</view></view><text style="color:#ccc;">→</text>
    </view>
  </view>

  <!-- Login modal -->
  <view wx:if="{{showLogin}}" style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:100;display:flex;align-items:center;justify-content:center;">
    <view style="background:#fff;border-radius:16rpx;padding:40rpx;width:560rpx;">
      <view style="font-size:34rpx;font-weight:bold;margin-bottom:25rpx;">账号登录</view>
      <input placeholder="用户名" bindinput="onUsernameInput" style="width:100%;height:80rpx;border:1rpx solid #e0e0e0;border-radius:12rpx;padding:0 20rpx;margin-bottom:15rpx;font-size:28rpx;"/>
      <input type="password" placeholder="密码" bindinput="onPasswordInput" style="width:100%;height:80rpx;border:1rpx solid #e0e0e0;border-radius:12rpx;padding:0 20rpx;margin-bottom:15rpx;font-size:28rpx;"/>
      <button class="btn-primary" style="width:100%;" bindtap="doLogin">登录</button>
      <button style="width:100%;margin-top:10rpx;background:#f0f0f0;border:none;border-radius:12rpx;padding:20rpx;font-size:28rpx;" bindtap="cancelLogin">取消</button>
    </view>
  </view>

  <view class="card" style="text-align:center;">
    <view style="font-size:24rpx;color:#999;">智慧图书管理系统 v2.0</view>
    <view style="font-size:22rpx;color:#ccc;">支持 Web + 微信小程序 | 云托管部署</view>
  </view>
</view>
